---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blogPosts';
import { ArrowRight, CheckCircle2 } from 'lucide-astro';
import { getWhatsappUrl } from '../../data/site';

export function getStaticPaths() {
  return blogPosts
    .filter((post) => !post.href)
    .map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const date = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }).format(new Date(`${post.pubDate}T12:00:00`));
---

<BaseLayout title={post.title} description={post.description} image={post.image} type="article">
  <main>
    <article>
      <header class="bg-primary pt-32 text-white">
        <div class="section-padding py-20">
          <p class="section-eyebrow text-amber-200">{post.category}</p>
          <h1 class="mt-4 max-w-4xl text-4xl text-white sm:text-5xl lg:text-6xl">{post.articleTitle ?? post.title}</h1>
          <p class="mt-5 text-white/75">{date}</p>
        </div>
      </header>
      <img class="h-[320px] w-full object-cover md:h-[460px]" src={post.image} alt={`Imagem de capa: ${post.title}`} loading="eager" />
      {post.sections ? (
        <div class="section-padding max-w-5xl">
          <div class="mx-auto max-w-3xl">
            <p class="text-lg leading-8 text-text-muted">{post.description}</p>
            <div class="mt-8 space-y-6 text-base leading-8 text-text-muted">
              {post.intro?.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>

          <div class="mx-auto mt-12 grid max-w-5xl gap-6">
            {post.sections.map((section) => (
              <section class="rounded-[28px] border border-emerald-950/10 bg-white p-6 shadow-sm sm:p-8">
                <h2 class="text-3xl text-primary sm:text-4xl">{section.heading}</h2>

                {section.paragraphs?.length ? (
                  <div class="mt-5 space-y-5 text-base leading-8 text-text-muted">
                    {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                  </div>
                ) : null}

                {section.bullets?.length ? (
                  <div class="mt-6 grid gap-3">
                    {section.bullets.map((item) => (
                      <p class="flex items-start gap-3 rounded-2xl border border-emerald-950/10 bg-background px-4 py-3 text-sm font-semibold leading-7 text-text-main">
                        <CheckCircle2 class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                        <span>{item}</span>
                      </p>
                    ))}
                  </div>
                ) : null}

                {section.table ? (
                  <div class="mt-6 overflow-x-auto rounded-2xl border border-emerald-950/10">
                    <table class="min-w-[760px] w-full border-collapse bg-white text-left text-sm">
                      <thead class="bg-primary text-white">
                        <tr>
                          {section.table.headers.map((header) => (
                            <th class="px-4 py-4 font-black">{header}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-emerald-950/10">
                        {section.table.rows.map((row) => (
                          <tr class="odd:bg-background/70">
                            {row.map((cell) => (
                              <td class="px-4 py-4 font-semibold leading-6 text-text-main">{cell}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                ) : null}

                {section.terrainMethods?.length ? (
                  <div class="mt-6 grid gap-4 md:grid-cols-3">
                    {section.terrainMethods.map((item) => (
                      <article class="rounded-3xl border border-emerald-950/10 bg-background p-5">
                        <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">{item.terrain}</p>
                        <p class="mt-3 text-sm font-semibold leading-7 text-text-main">{item.method}</p>
                        <p class="mt-3 text-sm leading-7 text-text-muted">{item.impact}</p>
                      </article>
                    ))}
                  </div>
                ) : null}
              </section>
            ))}
          </div>

          <section class="mx-auto mt-12 max-w-5xl rounded-[28px] border border-primary/10 bg-primary p-6 text-white shadow-sm sm:p-8">
            <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.22em] text-amber-200">Suporte Técnico</p>
                <h2 class="mt-3 text-3xl text-white sm:text-4xl">{post.ctaTitle ?? 'Precisa de apoio para planejar a estrutura?'}</h2>
                <p class="mt-4 text-base leading-8 text-white/80">
                  {post.ctaText ?? 'Nossa equipe pode orientar medidas, tipo de cobertura, logística de montagem e pontos importantes para uma locação mais segura.'}
                </p>
              </div>
              <a
                class="inline-flex min-h-11 items-center justify-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-black text-dark transition hover:bg-amber-400"
                href={getWhatsappUrl('Olá, preciso de orientação técnica para locação de tenda')}
                target="_blank"
                rel="noopener noreferrer"
              >
                {post.ctaLabel ?? 'Falar com especialista'}
                <ArrowRight class="h-4 w-4" aria-hidden="true" />
              </a>
            </div>
          </section>
        </div>
      ) : (
        <div class="section-padding prose max-w-3xl text-text-muted">
          <p>{post.description}</p>
          <h2>Resumo prático</h2>
          <p>
            Este é um artigo placeholder para a estrutura inicial do blog. Substitua este conteúdo por orientações reais, exemplos do portfólio e informações revisadas antes da publicação final.
          </p>
          <h2>Como aplicar no seu projeto</h2>
          <p>
            Ao planejar a locação, reúna data, cidade, quantidade de pessoas, metragem aproximada e finalidade da estrutura. Esses dados ajudam a indicar o modelo mais adequado e agilizam o orçamento.
          </p>
          <p>
            Continue navegando por páginas como <a href="/aluguel-de-tendas-para-eventos">aluguel de tendas para eventos</a>, <a href="/aluguel-de-tenda-em-bh">aluguel de tenda em BH</a> e <a href="/aluguel-de-tendas-valor">aluguel de tendas valor</a>.
          </p>
        </div>
      )}
    </article>
  </main>
</BaseLayout>
