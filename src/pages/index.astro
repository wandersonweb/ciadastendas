---
import AboutPreview from '../components/AboutPreview.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Hero from '../components/Hero.astro';
import ModelsSection from '../components/ModelsSection.astro';
import QuickCTA from '../components/QuickCTA.astro';
import SocialProof from '../components/SocialProof.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout title={site.metaTitle} description={site.metaDescription}>
  <main>
    <Hero />
    <QuickCTA />
    <ModelsSection />
    <AboutPreview />
    <BlogPreview />
    <SocialProof />
  </main>
</BaseLayout>
