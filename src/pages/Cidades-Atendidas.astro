---
import { ArrowRight, Building2, MapPin, TentTree } from 'lucide-astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { cidadesTendas } from '../data/cidadesTendas';

const cidadesOrdenadas = [...cidadesTendas].sort((a, b) =>
  a.cidade.localeCompare(b.cidade, 'pt-BR'),
);

const grupos = cidadesOrdenadas.reduce(
  (acc, item) => {
    const letra = item.cidade[0]?.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toUpperCase() ?? '#';
    const grupo = acc.find((entry) => entry.letra === letra);

    if (grupo) {
      grupo.cidades.push(item);
      return acc;
    }

    acc.push({ letra, cidades: [item] });
    return acc;
  },
  [] as { letra: string; cidades: typeof cidadesOrdenadas }[],
);

const destaques = [
  {
    icon: MapPin,
    title: `${cidadesOrdenadas.length + 1}+ cidades atendidas`,
    description: 'Uma malha local pensada para facilitar a descoberta das páginas e levar o visitante direto para a cidade desejada.',
  },
  {
    icon: TentTree,
    title: 'Mesma estrutura, conteúdo local',
    description: 'Cada página mantém o padrão visual do projeto, mas com foco próprio em eventos, regiões de referência e contexto comercial.',
  },
  {
    icon: Building2,
    title: 'Links internos mais fortes',
    description: 'Essa página concentra o acesso às cidades atendidas e ajuda o Google a encontrar e relacionar melhor as páginas locais.',
  },
];
---

<BaseLayout
  title="Cidades Atendidas"
  description="Veja as cidades atendidas pela Companhia Tenda e acesse rapidamente as páginas locais de aluguel de tendas para eventos."
>
  <main class="pb-20 pt-28 sm:pt-32">
    <section class="section-padding pt-8 lg:pt-12">
      <div class="overflow-hidden rounded-[32px] border border-emerald-950/10 bg-white shadow-[0_28px_80px_-40px_rgba(16,63,42,0.45)]">
        <div class="grid gap-10 px-6 py-10 sm:px-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] lg:px-12 lg:py-14">
          <div class="min-w-0">
            <p class="section-eyebrow">Navegação Local</p>
            <h1 class="mt-4 max-w-4xl text-4xl leading-tight text-primary sm:text-5xl lg:text-6xl">
              Cidades Atendidas
            </h1>
            <p class="mt-5 max-w-3xl text-base leading-8 text-text-muted sm:text-lg">
              Reunimos aqui todas as páginas locais de aluguel de tendas para facilitar a navegação dos visitantes e fortalecer a estrutura de links internos do site. Escolha a cidade desejada e acesse a página correspondente.
            </p>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-text-muted [&_a]:font-semibold [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-4 hover:[&_a]:text-accent">
              Se preferir, você também pode começar pelas páginas principais de <a href="/aluguel-de-tenda-em-bh">aluguel de tendas em BH</a>, <a href="/aluguel-de-tendas-para-eventos">aluguel de tendas para eventos</a>, <a href="/aluguel-de-tenda-para-casamento">aluguel de tenda para casamento</a>, <a href="/aluguel-de-tendas-valor">aluguel de tendas valor</a>, <a href="/aluguel-de-toldos">aluguel de toldos</a> ou pela página local de <a href="/aluguel-de-tendas-em-contagem">Contagem</a>.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <span class="inline-flex min-h-11 items-center rounded-full bg-primary px-5 py-3 text-sm font-bold text-white">
                {cidadesOrdenadas.length + 1} páginas locais
              </span>
              <a class="inline-flex min-h-11 items-center rounded-full border border-primary/15 bg-background px-5 py-3 text-sm font-bold text-primary transition hover:border-primary/35 hover:bg-primary/5" href="/contato">
                Falar sobre atendimento na minha cidade
              </a>
            </div>
          </div>

          <div class="grid gap-4 self-start">
            {destaques.map(({ icon: Icon, title, description }) => (
              <div class="rounded-3xl border border-emerald-950/10 bg-background/80 p-5">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-white shadow-sm">
                  <Icon class="h-5 w-5" aria-hidden="true" />
                </div>
                <h2 class="mt-4 text-xl text-primary">{title}</h2>
                <p class="mt-2 text-sm leading-7 text-text-muted">{description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding pt-0">
      <div class="grid gap-6 lg:grid-cols-[220px_minmax(0,1fr)]">
        <aside class="h-fit rounded-[28px] border border-emerald-950/10 bg-white p-5 shadow-sm">
          <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">Índice</p>
          <nav aria-label="Letras das cidades" class="mt-4 flex flex-wrap gap-2">
            {grupos.map((grupo) => (
              <a class="inline-flex h-11 min-w-11 items-center justify-center rounded-2xl border border-primary/10 bg-background px-3 text-sm font-bold text-primary transition hover:border-primary/30 hover:bg-primary/5" href={`#grupo-${grupo.letra}`}>
                {grupo.letra}
              </a>
            ))}
          </nav>
        </aside>

        <div class="grid gap-6">
          <div class="rounded-[28px] border border-emerald-950/10 bg-white p-6 shadow-sm sm:p-8">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="section-eyebrow">Página índice</p>
                <h2 class="mt-3 text-3xl text-primary">Links para todas as cidades</h2>
              </div>
              <p class="max-w-2xl text-sm leading-7 text-text-muted">
                Além das cidades listadas abaixo, você também pode acessar a página dedicada a <a class="font-semibold text-primary underline underline-offset-4 hover:text-accent" href="/aluguel-de-tenda-em-bh">Belo Horizonte</a>.
              </p>
            </div>

            <div class="mt-6">
              <a class="group flex items-center justify-between gap-4 rounded-3xl border border-primary/10 bg-background px-5 py-4 transition hover:border-primary/30 hover:bg-primary/5" href="/aluguel-de-tenda-em-bh">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.18em] text-accent">Capital</p>
                  <p class="mt-1 text-lg font-extrabold text-primary">Belo Horizonte</p>
                </div>
                <ArrowRight class="h-5 w-5 text-primary transition group-hover:translate-x-1" aria-hidden="true" />
              </a>
            </div>

            <div class="mt-8 grid gap-6">
              {grupos.map((grupo) => (
                <section id={`grupo-${grupo.letra}`} class="scroll-mt-32 rounded-3xl border border-emerald-950/10 bg-background/65 p-5 sm:p-6">
                  <div class="flex items-center gap-3">
                    <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-lg font-black text-white">
                      {grupo.letra}
                    </span>
                    <div>
                      <h3 class="text-2xl text-primary">Cidades com {grupo.letra}</h3>
                      <p class="text-sm text-text-muted">{grupo.cidades.length} página(s) local(is) nesta seção.</p>
                    </div>
                  </div>

                  <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
                    {grupo.cidades.map((cidade) => (
                      <a
                        class="group rounded-3xl border border-white bg-white px-5 py-4 shadow-sm transition hover:-translate-y-0.5 hover:border-primary/20 hover:shadow-lg"
                        href={`/${cidade.slug}`}
                      >
                        <div class="flex items-start justify-between gap-4">
                          <div>
                            <p class="text-lg font-extrabold text-primary">{cidade.cidade}</p>
                            <p class="mt-2 text-sm leading-7 text-text-muted">{cidade.regiao}</p>
                          </div>
                          <ArrowRight class="mt-1 h-5 w-5 shrink-0 text-primary transition group-hover:translate-x-1" aria-hidden="true" />
                        </div>
                      </a>
                    ))}
                  </div>
                </section>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
