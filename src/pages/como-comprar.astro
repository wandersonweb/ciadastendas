    text: 'Estrutura com proteção reforçada contra corrosão, indicada para usos frequentes e ambientes mais expostos.',
    headingTag: 'h3',
  },
  {
    title: 'Tenda Piramidal com Calha',
    text: 'Boa solução para acoplamento entre módulos, corredores cobertos e áreas formadas por várias tendas conectadas.',
    headingTag: 'h3',
  },
  {
    title: 'Tenda Chapéu de Bruxa com Calha',
    text: 'Une apresentação visual com funcionalidade, ajudando na criação de áreas maiores com melhor direcionamento de água.',
    headingTag: 'h3',
  },
  {
    title: 'Tenda Sanfonada',
    text: 'Estrutura dobrável com montagem rápida, indicada para feiras, eventos menores, ativações e pontos de venda.',
    headingTag: 'h3',
  },
];

const sanfonadas = [
  {
    title: 'Tenda Super Sanfonada de Aço 3x3',
    text: 'Compacta, prática e versátil para feiras, ações comerciais, recepções e pontos de apoio.',
  },
  {
    title: 'Tenda Super Sanfonada de Aço 4,5x3',
    text: 'Área intermediária de cobertura para quem precisa de mais espaço sem partir para uma estrutura maior.',
  },
  {
    title: 'Tenda Super Sanfonada de Aço 6x3',
    text: 'Maior área coberta com montagem e transporte facilitados para eventos, feiras e ações promocionais.',
  },
  {
    title: 'Tenda Sanfonada Profissional',
    text: 'Estrutura reforçada para uso frequente, indicada para empresas, expositores, locadores e organizadores.',
  },
];

const piramidais = [
  {
    title: 'Tenda Piramidal Profissional com Calhas Laterais',
    text: 'Indicada para grandes áreas cobertas e eventos com vários módulos conectados.',
  },
  {
    title: 'Tenda Piramidal Tubular',
    text: 'Estrutura metálica com tubos e encaixes para festas, feiras, recepções e coberturas ao ar livre.',
  },
  {
    title: 'Tenda Piramidal com Calha',
    text: 'Melhora o escoamento da água e a união entre estruturas em corredores e grandes eventos.',
  },
  {
    title: 'Tenda 6x6 com Calhas Laterais',
