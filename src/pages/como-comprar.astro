const priceFactors = [
  'Medidas da estrutura',
  'Tipo de cobertura',
  'Espessura dos tubos',
  'Tratamento anticorrosivo',
  'Modelo escolhido',
  'Presença de calhas',
  'Fechamentos laterais',
  'Personalizações',
  'Necessidade de transporte ou instalação',
