const availableModels = [
  {
    title: 'Venda de Tendas Para Eventos',
    text: 'Resumo rápido para quem busca comprar estruturas com foco em uso recorrente, praticidade operacional e melhor custo-benefício no longo prazo.',
    headingTag: 'h2',
  },
  {
    title: 'Tenda Piramidal',
    text: 'Modelo muito procurado para eventos, feiras e coberturas temporárias, com excelente aproveitamento da área coberta.',
    headingTag: 'h3',
  },
  {
    title: 'Tenda Chapéu de Bruxa',
    text: 'Formato elegante e acabamento visual diferenciado para recepções, casamentos, ações promocionais e eventos sociais.',
