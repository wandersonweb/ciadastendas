---
import { Home, MessageCircle, Search } from 'lucide-astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWhatsappUrl } from '../data/site';

const redirectDelaySeconds = 5;
const redirectDelayMs = redirectDelaySeconds * 1000;
---

<BaseLayout title="Página Não Encontrada" description="A página solicitada não foi encontrada no site da Companhia Tenda." noindex={true}>
  <main class="section-padding flex min-h-screen items-center pt-36">
    <section class="mx-auto max-w-3xl text-center">
      <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-primary/10 text-primary">
        <Search class="h-10 w-10" aria-hidden="true" />
      </div>
      <p class="mt-8 font-display text-8xl font-black text-primary/10" aria-hidden="true">404</p>
      <h1 class="mt-4 text-4xl text-primary sm:text-5xl">Página não encontrada</h1>
      <p class="mt-5 text-lg leading-8 text-text-muted">
        O endereço pode ter mudado ou não existir mais. Você pode voltar ao início ou falar com a equipe para solicitar um orçamento.
      </p>
      <p class="mt-3 text-sm font-semibold text-text-muted">
        Você será redirecionado para a página inicial em {redirectDelaySeconds} segundos.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a class="btn-primary" href="/">
          <Home class="h-5 w-5" aria-hidden="true" />
          Voltar ao início
        </a>
        <a class="inline-flex items-center justify-center gap-2 rounded-full border border-primary px-6 py-3 text-sm font-black text-primary transition hover:bg-primary hover:text-white" href={getWhatsappUrl()} target="_blank" rel="noopener noreferrer">
          <MessageCircle class="h-5 w-5" aria-hidden="true" />
          Falar no WhatsApp
        </a>
      </div>
    </section>
  </main>
  <script define:vars={{ redirectDelayMs }}>
    window.setTimeout(() => {
      window.location.replace('/');
    }, redirectDelayMs);
  </script>
</BaseLayout>
