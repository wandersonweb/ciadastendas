---
import { ArrowRight, BadgeCheck, ChevronRight, MessageCircle } from 'lucide-astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { productLinks, products } from '../../data/products';
import { getWhatsappUrl } from '../../data/site';
import { buildProductSchema } from '../../data/schema';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const relatedProducts = productLinks.filter((item) => item.href !== `/produtos/${product.slug}`);
---

<BaseLayout
  title={product.seoTitle}
  description={product.seoDescription}
  image={product.image}
  structuredData={[
    buildProductSchema({
      name: product.title,
      description: product.description,
      url: new URL(`/produtos/${product.slug}`, Astro.site ?? 'https://ciadastendas.com.br').href,
      image: product.image,
      category: 'Tendas e estruturas para eventos',
      additionalProperty: product.specs,
    }),
  ]}
>
  <main>
    <section class="relative overflow-hidden bg-primary pt-32 text-white">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(245,158,11,0.2),transparent_28%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.08),transparent_28%)]"></div>
      <div class="section-padding relative grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <div class="flex flex-wrap items-center gap-2 text-sm font-semibold text-white/70">
            <a href="/" class="transition hover:text-white">Início</a>
            <ChevronRight class="h-4 w-4" aria-hidden="true" />
            <a href="/produtos" class="transition hover:text-white">Produtos</a>
            <ChevronRight class="h-4 w-4" aria-hidden="true" />
            <span class="text-white">{product.shortTitle}</span>
          </div>

          <p class="mt-6 section-eyebrow text-amber-200">{product.eyebrow}</p>
          <h1 class="mt-4 max-w-3xl text-4xl leading-tight text-white sm:text-5xl lg:text-6xl">{product.title}</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-white/78">{product.description}</p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="btn-primary" href={getWhatsappUrl(`Olá, quero um orçamento para ${product.title.toLowerCase()}`)} target="_blank" rel="noopener noreferrer">
              Solicitar orçamento
            </a>
            <a class="btn-secondary" href="/como-comprar">
              Como comprar
            </a>
          </div>
        </div>

        <div class="overflow-hidden rounded-[32px] border border-white/12 bg-white/10 p-3 shadow-[0_30px_100px_-40px_rgba(0,0,0,0.4)] backdrop-blur">
          <img class="h-[340px] w-full rounded-[24px] object-cover lg:h-[460px]" src={product.image} alt={`Imagem ilustrativa de ${product.title}`} loading="eager" />
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="grid gap-10 lg:grid-cols-[1fr_340px]">
        <div class="space-y-10">
          <article class="rounded-[32px] border border-primary/10 bg-white p-6 shadow-sm sm:p-8">
            <p class="section-eyebrow">Visão geral</p>
            <h2 class="mt-3 text-3xl text-primary sm:text-4xl">Quando esse produto faz sentido?</h2>
            <div class="mt-6 space-y-5 text-base leading-8 text-text-muted">
              {product.intro.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </article>

          <article class="rounded-[32px] border border-primary/10 bg-white p-6 shadow-sm sm:p-8">
            <p class="section-eyebrow">Destaques</p>
            <h2 class="mt-3 text-3xl text-primary sm:text-4xl">Pontos fortes do {product.shortTitle}</h2>
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {product.highlights.map((item) => (
                <p class="flex items-start gap-3 rounded-[24px] border border-emerald-950/10 bg-background px-5 py-4 text-sm font-semibold leading-7 text-text-main">
                  <BadgeCheck class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
                  <span>{item}</span>
                </p>
              ))}
            </div>
          </article>

          <article class="rounded-[32px] border border-primary/10 bg-white p-6 shadow-sm sm:p-8">
            <p class="section-eyebrow">Aplicações</p>
            <h2 class="mt-3 text-3xl text-primary sm:text-4xl">Onde o {product.shortTitle} costuma ser usado</h2>
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {product.applications.map((item) => (
                <article class="rounded-[24px] border border-emerald-950/10 bg-background p-5">
                  <p class="text-lg font-black text-text-main">{item}</p>
                </article>
              ))}
            </div>
          </article>

          <article class="rounded-[32px] border border-primary/10 bg-white p-6 shadow-sm sm:p-8">
            <p class="section-eyebrow">Diferenciais</p>
            <h2 class="mt-3 text-3xl text-primary sm:text-4xl">Como nossa equipe orienta esse tipo de projeto</h2>
            <div class="mt-6 grid gap-4 md:grid-cols-3">
              {product.differentials.map((item) => (
                <article class="rounded-[24px] border border-emerald-950/10 bg-background p-5">
                  <h3 class="text-xl text-primary">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-text-muted">{item.text}</p>
                </article>
              ))}
            </div>
          </article>
        </div>

        <aside class="space-y-6">
          <article class="rounded-[32px] border border-primary/10 bg-dark p-6 text-white shadow-[0_30px_80px_-40px_rgba(8,22,16,0.8)]">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-amber-200">Especificações rápidas</p>
            <div class="mt-5 grid gap-4">
              {product.specs.map((item) => (
                <div class="rounded-[22px] border border-white/10 bg-white/8 p-4">
                  <p class="text-xs font-bold uppercase tracking-[0.16em] text-white/60">{item.label}</p>
                  <p class="mt-2 text-sm font-semibold leading-7 text-white">{item.value}</p>
                </div>
              ))}
            </div>
          </article>

          <article class="rounded-[32px] border border-primary/10 bg-white p-6 shadow-sm">
            <p class="section-eyebrow">Próximo passo</p>
            <h2 class="mt-3 text-2xl text-primary">Quer saber se esse é o produto ideal?</h2>
            <p class="mt-4 text-sm leading-7 text-text-muted">
              Envie o tipo de evento, a cidade, o tamanho do espaço e a quantidade de pessoas. A partir disso, orientamos a solução mais adequada.
            </p>
            <a class="btn-primary mt-6 w-full" href={getWhatsappUrl(`Olá, quero falar sobre ${product.title.toLowerCase()}`)} target="_blank" rel="noopener noreferrer">
              <MessageCircle class="h-5 w-5" aria-hidden="true" />
              Chamar no WhatsApp
            </a>
          </article>

          <article class="rounded-[32px] border border-primary/10 bg-white p-6 shadow-sm">
            <p class="section-eyebrow">Outros produtos</p>
            <div class="mt-5 grid gap-3">
              {relatedProducts.map((item) => (
                <a class="group flex items-center justify-between rounded-[20px] border border-emerald-950/10 bg-background px-4 py-3 text-sm font-bold text-text-main transition hover:border-primary/25 hover:text-primary" href={item.href}>
                  {item.title}
                  <ArrowRight class="h-4 w-4 transition group-hover:translate-x-1" aria-hidden="true" />
                </a>
              ))}
            </div>
          </article>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
