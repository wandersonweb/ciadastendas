---
import { Facebook, Instagram, Linkedin, Mail, MapPin, MessageCircle } from 'lucide-astro';
import { getWhatsappUrl, serviceLinks, site } from '../data/site';

const socialLinks = [
  { href: site.social.instagram, label: 'Instagram', Icon: Instagram },
  { href: site.social.facebook, label: 'Facebook', Icon: Facebook },
  { href: site.social.linkedin, label: 'LinkedIn', Icon: Linkedin },
].filter((item) => /^https?:\/\//.test(item.href));
---

<footer class="bg-dark text-white">
  <div class="section-padding pb-10">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <a href="/" class="inline-flex items-center gap-3">
          <img class="h-11 w-auto object-contain" src={site.logo} alt={site.name} />
        </a>
        <p class="mt-5 max-w-sm text-sm leading-7 text-white/70">
          Locação e venda de tendas elegantes, corporativas e industriais para eventos, empresas, feiras, casamentos e operações temporárias.
        </p>
        {socialLinks.length ? (
          <div class="mt-6 flex gap-3">
            {socialLinks.map(({ href, label, Icon }) => (
              <a class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition hover:bg-accent hover:text-dark" href={href} aria-label={label} target="_blank" rel="noopener noreferrer">
                <Icon class="h-5 w-5" aria-hidden="true" />
              </a>
            ))}
          </div>
        ) : null}
      </div>

      <div>
        <h2 class="text-lg text-white">Links rápidos</h2>
        <nav class="mt-5 grid gap-3 text-sm text-white/72">
          <a class="hover:text-accent" href="/">Início</a>
          <a class="hover:text-accent" href="/produtos">Produtos</a>
          <a class="hover:text-accent" href="/como-comprar">Como comprar</a>
          <a class="hover:text-accent" href="/quem-somos">Sobre</a>
          <a class="hover:text-accent" href="/blog">Blog</a>
          <a class="hover:text-accent" href="/contato">Contato</a>
          {serviceLinks.slice(1, 3).map((link) => (
            <a class="hover:text-accent" href={link.href}>{link.title}</a>
          ))}
        </nav>
      </div>

      <div>
        <h2 class="text-lg text-white">Contato</h2>
        <div class="mt-5 grid gap-4 text-sm text-white/72">
          <a class="flex gap-3 hover:text-accent" href={getWhatsappUrl()} target="_blank" rel="noopener noreferrer">
            <MessageCircle class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
            {site.phone}
          </a>
          <a class="flex gap-3 hover:text-accent" href={`mailto:${site.email}`}>
            <Mail class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
            {site.email}
          </a>
          <p class="flex gap-3">
            <MapPin class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
            {site.address}
          </p>
        </div>
      </div>
    </div>
    <div class="mt-12 border-t border-white/10 pt-6 text-sm text-white/55">
      <p>© {new Date().getFullYear()} {site.name}. Todos os direitos reservados. ciadastendas.com.br</p>
    </div>
  </div>
</footer>
