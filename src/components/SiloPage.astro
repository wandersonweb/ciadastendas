---
import { ArrowRight, CheckCircle2, Landmark, MessageCircle, Tent, Zap } from 'lucide-astro';
import AboutPreview from './AboutPreview.astro';
import BlogPreview from './BlogPreview.astro';
import { getWhatsappUrl, siloNetworkLinks } from '../data/site';

interface ArticleImage {
  src: string;
  alt: string;
}

interface ArticleSection {
  level: 2 | 3;
  heading: string;
  paragraphs: string[];
  listItems?: string[];
}

interface FeaturedModel {
  title: string;
  description: string;
  icon: 'tent' | 'zap' | 'landmark';
}

interface RelatedLink {
  title: string;
  href: string;
}

interface Props {
  slug?: string;
  title: string;
  intro: string;
  heroEyebrow?: string;
  heroChecklist?: string[];
  ctaBannerText?: string;
  articleEyebrow?: string;
  articleTitle?: string;
  articleTitleTag?: 'h2' | 'p';
  articleLead?: string[];
  articleSections?: ArticleSection[];
  articleImages?: ArticleImage[];
  featuredModels?: FeaturedModel[];
  relatedLinks?: RelatedLink[];
}

const {
  slug = '',
  title,
  intro,
  heroEyebrow = 'Locação de estruturas em Minas Gerais',
  heroChecklist = [],
  ctaBannerText = 'Receba uma orientação rápida para escolher a tenda certa para seu evento ou operação.',
  articleEyebrow = 'Guia prático',
  articleTitle = `Como planejar ${title.toLowerCase()} com mais segurança`,
  articleTitleTag = 'h2',
  articleLead = [],
  articleSections = [],
  articleImages = [],
  featuredModels = [],
  relatedLinks = [],
} = Astro.props;

const related = (relatedLinks.length ? relatedLinks : siloNetworkLinks)
  .filter((link) => link.title !== title && link.href !== `/${slug}`)
  .slice(0, 8);

const iconMap = {
  tent: Tent,
  zap: Zap,
  landmark: Landmark,
} as const;
---

<main>
  <section class="relative overflow-hidden bg-primary pt-28 text-white">
    <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(8,22,16,0.94),rgba(16,63,42,0.74),rgba(245,158,11,0.2)),url('/images/banner-aluguel-venda-tenda.webp')] bg-cover bg-center"></div>
    <div class="section-padding relative grid gap-10 py-20 lg:grid-cols-[1fr_390px] lg:items-end lg:py-24">
      <div>
        <p class="section-eyebrow text-amber-200">{heroEyebrow}</p>
        <h1 class="mt-4 max-w-4xl break-words text-3xl leading-tight text-white sm:text-5xl lg:text-6xl">{title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-white/85">{intro}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="btn-primary w-full sm:w-auto" href={getWhatsappUrl(`Olá, quero um orçamento para ${title.toLowerCase()}`)} target="_blank" rel="noopener noreferrer">
            <MessageCircle class="h-5 w-5" aria-hidden="true" />
            Solicitar orçamento
          </a>
          <a class="btn-secondary w-full sm:w-auto" href="#artigo">
            Ver detalhes da locação
            <ArrowRight class="h-5 w-5" aria-hidden="true" />
          </a>
        </div>
      </div>

      <div class="rounded-2xl border border-white/15 bg-white/12 p-5 shadow-2xl backdrop-blur">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-amber-200">Atendimento consultivo</p>
        <div class="mt-5 grid gap-4">
          {heroChecklist.map((item) => (
            <p class="flex items-center gap-3 text-sm font-bold text-white">
              <CheckCircle2 class="h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
              {item}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-accent text-dark">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-6 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
      <p class="max-w-3xl font-display text-2xl font-black leading-tight md:text-3xl">
        {ctaBannerText}
      </p>
      <a class="inline-flex min-h-12 w-full items-center justify-center gap-2 rounded-full bg-dark px-6 py-3 text-sm font-black text-white transition hover:bg-primary focus:outline-none focus:ring-4 focus:ring-dark/20 md:w-auto" href={getWhatsappUrl(`Olá, quero falar com um especialista sobre ${title.toLowerCase()}`)} target="_blank" rel="noopener noreferrer">
        <MessageCircle class="h-5 w-5" aria-hidden="true" />
        Falar com especialista
      </a>
    </div>
  </section>

  <section class="section-padding">
    <div class="grid gap-5 md:grid-cols-3">
      {featuredModels.map((model) => {
        const Icon = iconMap[model.icon];
        return (
          <article class="group rounded-2xl border border-emerald-950/10 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-primary/25 hover:shadow-xl">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary text-white shadow-lg shadow-primary/15 transition duration-300 group-hover:bg-accent group-hover:text-dark">
              <Icon class="h-7 w-7" aria-hidden="true" />
            </div>
            <p class="mt-5 font-display text-2xl font-extrabold text-primary">{model.title}</p>
            <p class="mt-3 leading-7 text-text-muted">{model.description}</p>
          </article>
        );
      })}
    </div>
  </section>

  <article id="artigo" class="section-padding grid gap-10 pt-0 lg:grid-cols-[minmax(0,1fr)_360px]">
    <div class="rounded-2xl bg-white p-6 shadow-sm sm:p-8 lg:p-10">
      <div class="mb-8 border-b border-emerald-950/10 pb-8">
        <div>
          <p class="section-eyebrow">{articleEyebrow}</p>
          {articleTitleTag === 'h2' ? (
            <h2 class="mt-3 break-words text-3xl text-primary sm:text-4xl">{articleTitle}</h2>
          ) : (
            <p class="mt-3 font-display text-3xl font-extrabold break-words text-primary sm:text-4xl">{articleTitle}</p>
          )}
        </div>
      </div>

      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-5">
        {articleImages.map((image) => (
          <img
            class="aspect-[4/3] w-full rounded-xl object-cover"
            src={image.src}
            alt={image.alt}
            loading="lazy"
            width="420"
            height="315"
          />
        ))}
      </div>

      <div class="prose max-w-none text-text-muted [&_a]:font-semibold [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-4 hover:[&_a]:text-accent">
        {articleLead.map((paragraph) => (
          <p set:html={paragraph} />
        ))}

        {articleSections.map((section) => {
          const HeadingTag = section.level === 2 ? 'h2' : 'h3';
          return (
            <section>
              <HeadingTag>{section.heading}</HeadingTag>
              {section.paragraphs.map((paragraph) => (
                <p set:html={paragraph} />
              ))}
              {section.listItems?.length ? (
                <ul>
                  {section.listItems.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              ) : null}
            </section>
          );
        })}

        <section>
          <p>
            Seu evento merece uma estrutura segura, confortável e preparada para qualquer situação. Entre em contato com a Companhia Tenda e receba uma proposta personalizada para o seu projeto.
          </p>
          <p>
            Nossa equipe está pronta para ajudar você a escolher a melhor solução, com atendimento rápido e condições especiais. Não deixe para a última hora. Solicite seu orçamento agora e descubra como podemos transformar seu evento em uma experiência ainda mais organizada, confortável e profissional.
          </p>
        </section>
      </div>
    </div>

    <aside class="h-fit rounded-2xl border border-emerald-950/10 bg-white p-6 shadow-sm lg:sticky lg:top-28">
      <p class="font-display text-xl font-extrabold text-primary">Páginas relacionadas</p>
      <nav class="mt-5 grid gap-3">
        {related.map((link) => (
          <a class="flex min-h-12 items-center justify-between gap-3 rounded-xl bg-background px-4 py-3 text-sm font-bold text-text-main transition hover:bg-primary hover:text-white focus:outline-none focus:ring-4 focus:ring-primary/15" href={link.href}>
            {link.title}
            <ArrowRight class="h-4 w-4 shrink-0" aria-hidden="true" />
          </a>
        ))}
      </nav>
      <a class="btn-primary mt-6 w-full" href={getWhatsappUrl()} target="_blank" rel="noopener noreferrer">
        <MessageCircle class="h-5 w-5" aria-hidden="true" />
        Falar com especialista
      </a>
    </aside>
  </article>

  <AboutPreview />
  <BlogPreview />
</main>
