---
import BlogCard from './BlogCard.astro';

const homeCommercialCards = [
  {
    slug: 'eventos',
    title: 'Aluguel de Tendas para Eventos',
    description: 'Estruturas seguras e elegantes para eventos sociais, corporativos, feiras e ações promocionais.',
    category: 'Eventos',
    pubDate: '2026-05-12',
    image: '/images/aluguel-tendas-eventos.webp',
    href: '/eventos',
    ctaLabel: 'Ver página',
  },
  {
    slug: 'aluguel-de-tenda-em-bh',
    title: 'Aluguel de Tenda em BH',
    description: 'Atendimento em Belo Horizonte para eventos, empresas, feiras e operações temporárias.',
    category: 'Belo Horizonte',
    pubDate: '2026-05-19',
    image: '/images/aluguel-tendas-bh.webp',
    href: '/aluguel-de-tenda-em-bh',
    ctaLabel: 'Ver página',
  },
  {
    slug: 'venda-de-tendas',
    title: 'Venda de Tendas',
    description: 'Veja modelos profissionais, aplicações e orientações para comprar a estrutura certa para eventos e uso recorrente.',
    category: 'Venda',
    pubDate: '2026-05-26',
    image: '/images/venda-de-tendas.webp',
    href: '/como-comprar',
    ctaLabel: 'Ver página',
  },
  {
    slug: 'aluguel-de-tenda-para-casamento',
    title: 'Aluguel de Tenda para Casamento',
    description: 'Coberturas elegantes para cerimônias, recepções, lounges, buffet e áreas de circulação.',
    category: 'Casamentos',
    pubDate: '2026-06-02',
    image: '/images/aluguel-venda-tenda-casamento.webp',
    href: '/aluguel-de-tenda-para-casamento',
    ctaLabel: 'Ver página',
  },
  {
    slug: 'aluguel-de-toldos',
    title: 'Aluguel de Toldos',
    description: 'Toldos e coberturas temporárias para entradas, áreas de apoio, eventos e demandas comerciais.',
    category: 'Toldos',
    pubDate: '2026-06-09',
    image: '/images/aluguel-de-toldo.webp',
    href: '/aluguel-de-toldos',
    ctaLabel: 'Ver página',
  },
  {
    slug: 'aluguel-de-tendas-em-contagem',
    title: 'Aluguel de Tendas em Contagem',
    description: 'Locação de tendas para eventos corporativos, industriais, feiras e demandas temporárias em Contagem.',
    category: 'Contagem',
    pubDate: '2026-06-15',
    image: '/images/aluguel-venda-tenda-contagem.webp',
