---

<section class="section-padding">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="max-w-3xl">
      <p class="section-eyebrow">Conteúdo técnico</p>
      <h2 class="mt-3 text-4xl text-primary sm:text-5xl">Últimos posts do blog</h2>
      <p class="mt-5 text-lg leading-8 text-text-muted">Guias práticos para planejar locação, montagem, segurança e dimensionamento de tendas.</p>
    </div>
    <a class="font-black text-primary transition hover:text-accent" href="/blog">Ver todos os artigos</a>
  </div>
  <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {homeCommercialCards.map((post) => <BlogCard {...post} />)}
  </div>
</section>
