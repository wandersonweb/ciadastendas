---
import { Hammer, Droplets, Sparkles, Layers, ShieldCheck, Home } from 'lucide-astro';
import { services } from '../data/services';
import { site } from '../data/site';

const icons = { Hammer, Droplets, Sparkles, Layers, ShieldCheck, Home };
const serviceCards = services.map((service) => ({
  ...service,
  href: `/${service.slug}`,
  icon: icons[service.icon as keyof typeof icons] ?? Sparkles,
}));
---

<section id="servicos" class="section-padding bg-background relative overflow-hidden">
  <!-- Decorative grain texture -->
  <div class="absolute inset-0 opacity-[0.02] bg-[url('data:image/svg+xml,%3Csvg viewBox=\"0 0 256 256\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cfilter id=\"noise\"%3E%3CfeTurbulence type=\"fractalNoise\" baseFrequency=\"0.9\" numOctaves=\"4\" stitchTiles=\"stitch\"/%3E%3C/filter%3E%3Crect width=\"100%25\" height=\"100%25\" filter=\"url(%23noise)\"/%3E%3C/svg%3E')] -z-10"></div>
  <div class="text-center max-w-3xl mx-auto mb-16 space-y-6">
    <p class="section-eyebrow">Especialidades</p>
    <h2 class="text-4xl lg:text-5xl font-serif text-text-main">Soluções completas para <em class="text-primary not-italic">{site.mainService}</em></h2>
    <p class="text-text-muted text-lg">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer vitae justo non lectus facilisis posuere.
    </p>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
    {serviceCards.map(service => (
      <a href={service.href} class="card-premium group p-8 bg-white border-transparent flex flex-col">
        <div class="w-14 h-14 bg-primary/8 rounded-2xl flex items-center justify-center text-primary group-hover:bg-[#C9A84C]/15 group-hover:text-[#C9A84C] transition-all duration-300 mb-6">
          <service.icon class="w-7 h-7" />
        </div>
        <h3 class="text-xl font-serif text-text-main mb-3 group-hover:text-primary transition-colors">{service.title}</h3>
        <p class="text-text-muted text-sm leading-relaxed mb-6 flex-1">
          {service.description}
        </p>
        <span class="text-primary font-bold text-xs uppercase tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all duration-300">
          Saiba Mais
          <span class="text-base">→</span>
        </span>
      </a>
    ))}
  </div>
</section>
