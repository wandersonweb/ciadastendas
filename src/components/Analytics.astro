---
// Analytics.astro
// Template limpo: adicione aqui os scripts de rastreamento do novo projeto.
const GA_ID = "{{GA_ID}}";
const hasAnalytics = !GA_ID.includes("{{");
---

{hasAnalytics && (
  <>
    <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script type="text/partytown" define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>
  </>
)}
