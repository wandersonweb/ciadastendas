---
import { getCollection, type CollectionEntry } from 'astro:content';
import { ArrowRightCircle } from 'lucide-astro';
import { site } from '../data/site';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<section class="section-padding bg-white relative">
  <div class="absolute top-0 right-0 w-1/3 h-full bg-background rounded-l-full -z-10 opacity-50"></div>
  <div class="text-center mb-16 space-y-4">
    <p class="section-eyebrow">Blog & Conteúdo</p>
    <h2 class="text-4xl md:text-5xl font-serif text-text-main leading-tight">
      Inspire-se com as <em class="text-primary not-italic">Novidades</em>
    </h2>
    <div class="flex items-center justify-center gap-4">
      <div class="h-px w-16 bg-stone-200"></div>
      <div class="w-2 h-2 rounded-full bg-accent"></div>
      <div class="h-px w-16 bg-stone-200"></div>
    </div>
  </div>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-8">
    {posts.map((post: CollectionEntry<'blog'>) => (
      <article class="flex flex-col group">
        <a href={`/blog/${post.id}`} class="block relative aspect-[4/3] overflow-hidden rounded-3xl shadow-md">
          <img 
            src={post.data.heroImage || site.ogImage} 
            alt={post.data.title}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
          />
          <!-- The overlapping box -->
          <div class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur p-6 rounded-2xl shadow-sm border-l-4 border-accent group-hover:shadow-xl transition-all duration-300 transform group-hover:-translate-y-2">
            <h3 class="text-lg font-bold text-primary mb-2 leading-snug group-hover:text-secondary transition-colors line-clamp-2">
              {post.data.title}
            </h3>
            <p class="text-text-muted text-xs leading-relaxed line-clamp-2 mb-4">
              {post.data.description}
            </p>
            <div class="flex items-center gap-2 text-[11px] font-bold text-text-muted uppercase tracking-widest">
              LER MAIS 
              <ArrowRightCircle class="w-4 h-4 text-accent" />
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
  
  <div class="mt-16 text-center">
    <a href="/blog" class="btn-primary px-10 py-4 text-lg">
      Ver Todos os Posts
    </a>
  </div>
</section>
