---
import { MapPin, Star } from 'lucide-astro';
import { stats, testimonials } from '../data/testimonials';
---

<section class="section-padding relative overflow-hidden bg-background">
  <div class="absolute -right-16 -top-20 h-56 w-56 rounded-[3rem] border border-primary/6 bg-white/60 blur-2xl"></div>
  <div class="absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-accent/8 blur-3xl"></div>

  <div class="relative grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
    <div class="space-y-8">
      <div class="max-w-xl">
        <p class="section-eyebrow">Social Proof</p>
        <h2 class="mt-4 text-4xl leading-tight text-text-main sm:text-5xl">
          Confiança construída
          <span class="block text-primary">evento por evento</span>
        </h2>
        <p class="mt-5 text-lg leading-8 text-text-muted">
          Atendimento claro, montagem no prazo e estrutura pensada para cada espaço. Essa é a combinação que mais aparece nas avaliações de quem contrata a Companhia Tenda.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-5">
        {stats.map((stat) => (
          <article class="rounded-[28px] border border-primary/10 bg-white p-5 shadow-[0_18px_50px_-30px_rgba(16,63,42,0.35)] transition duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-[0_28px_70px_-34px_rgba(16,63,42,0.42)]">
            <p class="text-4xl font-black text-primary">{stat.value}</p>
            <p class="mt-2 text-sm font-bold uppercase tracking-[0.16em] text-text-muted">{stat.label}</p>
          </article>
        ))}
      </div>

      <article class="relative overflow-hidden rounded-[30px] bg-dark p-7 text-white shadow-[0_26px_70px_-34px_rgba(8,22,16,0.7)]">
        <div class="absolute -right-8 -top-8 h-28 w-28 rounded-full bg-white/8 blur-2xl"></div>
        <p class="max-w-md text-lg font-semibold italic leading-8 text-white/90">
          "Estrutura bem montada, atendimento ágil e orientação sincera para escolher a cobertura certa."
        </p>
        <div class="mt-6 flex items-center gap-3 text-accent">
          {Array.from({ length: 5 }).map(() => <Star class="h-5 w-5 fill-current" aria-hidden="true" />)}
          <span class="text-sm font-black uppercase tracking-[0.18em] text-white">Google Reviews</span>
        </div>
      </article>
    </div>

    <div class="grid gap-7 md:grid-cols-2">
      {testimonials.map((testimonial, index) => (
        <article class:list={[
          "group rounded-[30px] border border-primary/10 bg-white p-7 shadow-[0_18px_50px_-30px_rgba(16,63,42,0.3)] transition duration-300 hover:-translate-y-2 hover:border-primary/18 hover:shadow-[0_30px_80px_-38px_rgba(16,63,42,0.42)]",
          index === 2 && "md:col-span-2",
        ]}>
          <div class="flex items-center justify-between gap-4">
            <div class="flex gap-1 text-accent" aria-label={`Avaliação de ${testimonial.stars} estrelas`}>
              {Array.from({ length: testimonial.stars }).map(() => <Star class="h-5 w-5 fill-current" aria-hidden="true" />)}
            </div>
            <span class="rounded-full border border-primary/10 bg-background px-3 py-1 text-[11px] font-black uppercase tracking-[0.18em] text-primary">
              Google
            </span>
          </div>

          <p class="mt-6 text-lg font-medium leading-9 text-text-main italic">
            "{testimonial.content}"
          </p>

          <div class="mt-8 flex items-center gap-4">
            <div class="flex h-13 w-13 items-center justify-center rounded-full bg-primary text-base font-black text-white shadow-lg shadow-primary/20 transition duration-300 group-hover:scale-105">
              {testimonial.name
                .split(' ')
                .slice(0, 2)
                .map((part) => part.charAt(0))
                .join('')}
            </div>
            <div>
              <p class="text-xl font-black text-text-main">{testimonial.name}</p>
              <p class="mt-1 flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-text-muted">
                <MapPin class="h-4 w-4 text-accent" aria-hidden="true" />
                {testimonial.role}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
