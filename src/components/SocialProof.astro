---
import { Star } from 'lucide-astro';

// Depoimentos placeholders. Substituir por avaliações reais somente quando houver autorização e fonte confirmada.
const testimonials = [
  {
    name: 'Cliente corporativo placeholder',
    text: 'Atendimento organizado, montagem no prazo e estrutura com acabamento profissional para nossa ação.',
  },
  {
    name: 'Organizador de evento placeholder',
    text: 'A equipe ajudou no dimensionamento e entregou uma solução adequada para recepção e área de apoio.',
  },
  {
    name: 'Cliente social placeholder',
    text: 'A tenda trouxe segurança para o evento e ficou muito bem integrada ao espaço da celebração.',
  },
];
---

<section class="bg-primary text-white">
  <div class="section-padding">
    <div class="max-w-3xl">
      <p class="section-eyebrow text-amber-200">Prova social</p>
      <h2 class="mt-3 text-4xl text-white sm:text-5xl">Confiança para eventos que não podem improvisar.</h2>
      <p class="mt-5 text-lg leading-8 text-white/75">Os depoimentos abaixo são placeholders e devem ser substituídos por informações reais depois.</p>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {testimonials.map((testimonial) => (
        <article class="rounded-2xl border border-white/15 bg-white/10 p-6 backdrop-blur">
          <div class="flex gap-1 text-accent" aria-label="Avaliação placeholder de 5 estrelas">
            {Array.from({ length: 5 }).map(() => <Star class="h-4 w-4 fill-current" aria-hidden="true" />)}
          </div>
          <p class="mt-5 leading-7 text-white/86">"{testimonial.text}"</p>
          <p class="mt-5 text-sm font-black text-amber-200">{testimonial.name}</p>
        </article>
      ))}
    </div>
  </div>
</section>
