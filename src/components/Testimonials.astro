---
import { Star, Quote } from 'lucide-astro';
import { stats, testimonials } from '../data/testimonials';
---

<section class="section-padding overflow-hidden bg-background relative">
  <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/5 rounded-full blur-3xl -z-10"></div>
  <div class="grid lg:grid-cols-3 gap-16 items-center">
    <!-- Stats -->
    <div class="lg:col-span-1 space-y-8">
      <div class="space-y-4">
        <p class="section-eyebrow">Social Proof</p>
        <h2 class="text-4xl lg:text-5xl font-serif text-text-main leading-tight">Aprovação de quem <em class="text-primary not-italic">confia</em> no nosso trabalho</h2>
      </div>

      <div class="grid grid-cols-2 gap-6">
        {stats.map(stat => (
          <div class="space-y-1">
            <p class="text-4xl font-bold text-primary">{stat.value}</p>
            <p class="text-xs font-bold text-text-muted uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
      
      <div class="p-8 bg-primary rounded-[2rem] text-white space-y-4 shadow-xl relative overflow-hidden">
        <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/10 rounded-full blur-xl"></div>
        <p class="text-base font-medium opacity-90 italic">"Uma experiência transformadora, que trouxe vida e harmonia para o meu dia a dia."</p>
        <div class="flex items-center gap-3">
          <div class="flex">
            {[1,2,3,4,5].map(() => <Star class="w-5 h-5 fill-accent text-accent" />)}
          </div>
          <span class="text-xs font-bold uppercase tracking-widest text-white/80">Avaliações</span>
        </div>
      </div>
    </div>

    <!-- Testimonials -->
    <div class="lg:col-span-2 grid md:grid-cols-2 gap-8 relative">
      <div class="absolute -top-12 -right-12 text-primary/10 -z-10">
        <Quote class="w-48 h-48" />
      </div>

      {testimonials.map((t, i) => (
        <div class={i === 2 ? "md:col-span-2 card-premium p-10 bg-white" : "card-premium p-10 bg-white"}>
          <div class="flex gap-1 mb-6">
            {Array.from({ length: t.stars }).map(() => <Star class="w-5 h-5 fill-yellow-500 text-yellow-500" />)}
          </div>
          <p class="text-text-main font-serif font-medium mb-8 text-2xl leading-relaxed italic">
            "{t.content}"
          </p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary font-bold">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-text-main text-lg">{t.name}</p>
              <p class="text-xs text-text-muted uppercase font-bold tracking-widest">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
