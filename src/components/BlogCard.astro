---
interface Props {
  slug: string;
  title: string;
  description?: string;
  category: string;
  pubDate: string;
  image: string;
  href?: string;
  ctaLabel?: string;
}

const { slug, title, description, category, pubDate, image, href, ctaLabel = 'Ler artigo' } = Astro.props;
const date = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }).format(new Date(`${pubDate}T12:00:00`));
const cardHref = href ?? `/blog/${slug}`;
---

<article class="card-premium group">
  <a href={cardHref} class="block overflow-hidden">
    <div class="relative aspect-[16/10] overflow-hidden">
      <img class="h-full w-full object-cover transition duration-500 group-hover:scale-105" src={image} alt={`Imagem de capa: ${title}`} loading="lazy" />
      <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1 text-xs font-black uppercase tracking-wider text-dark shadow">
        {category}
      </span>
    </div>
    <div class="p-5">
      <p class="text-sm font-semibold text-text-muted">{date}</p>
      <h3 class="mt-3 text-xl leading-snug text-primary">{title}</h3>
      {description && <p class="mt-3 line-clamp-3 text-sm leading-6 text-text-muted">{description}</p>}
      <span class="mt-5 inline-flex font-black text-accent">{ctaLabel}</span>
    </div>
  </a>
</article>
