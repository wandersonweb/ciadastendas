---
interface Props {
  title: string;
  description: string;
  icon: any;
  headingTag?: 'h2' | 'h3';
}

const { title, description, icon: Icon, headingTag = 'h3' } = Astro.props;
---

<article class="card-premium group p-6">
  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary text-white transition group-hover:bg-accent group-hover:text-dark">
    <Icon class="h-6 w-6" aria-hidden="true" />
  </div>
  {headingTag === 'h2' ? (
    <h2 class="mt-5 text-xl text-primary">{title}</h2>
  ) : (
    <h3 class="mt-5 text-xl text-primary">{title}</h3>
  )}
  <p class="mt-3 text-sm leading-7 text-text-muted">{description}</p>
</article>
