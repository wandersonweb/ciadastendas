---
import { MessageCircle } from 'lucide-astro';
import { getWhatsappUrl } from '../data/site';
---

<section class="bg-accent text-dark">
  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-6 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <p class="max-w-3xl font-display text-2xl font-black leading-tight md:text-3xl">
      Precisa alugar ou comprar uma tenda com montagem segura e acabamento profissional?
    </p>
    <a class="inline-flex items-center justify-center gap-2 rounded-full bg-dark px-6 py-3 text-sm font-black text-white transition hover:bg-primary focus:outline-none focus:ring-4 focus:ring-dark/20" href={getWhatsappUrl("Olá, quero falar com um especialista sobre aluguel ou compra de tenda")} target="_blank" rel="noopener noreferrer">
      <MessageCircle class="h-5 w-5" aria-hidden="true" />
      Falar com Especialista
    </a>
  </div>
</section>
