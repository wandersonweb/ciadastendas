---
import { ArrowRight, MessageCircle } from 'lucide-astro';
import { getWhatsappUrl } from '../data/site';
---

<section class="relative min-h-[720px] overflow-hidden bg-dark pt-32 text-white sm:min-h-[760px] lg:min-h-[820px]">
  <img
    class="absolute inset-0 h-full w-full object-cover"
    src="https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&fit=crop&w=2200&q=85"
    alt="Tenda tensionada montada para evento ao entardecer"
    loading="eager"
    decoding="async"
  />
  <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark/80 to-primary/55"></div>
  <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-background to-transparent"></div>

  <div class="section-padding relative flex min-h-[600px] items-center py-20 lg:py-28">
    <div class="max-w-4xl">
      <span class="inline-flex rounded-full border border-white/25 bg-white/12 px-4 py-2 text-xs font-black uppercase tracking-[0.2em] text-amber-200 backdrop-blur">
        Estruturas elegantes e homologadas
      </span>
      <h1 class="mt-7 max-w-3xl text-5xl leading-[0.95] text-white sm:text-6xl lg:text-8xl">
        Aluguel e Venda de Tenda
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-white/88 sm:text-xl">
        Estruturas seguras, elegantes e homologadas para locação e venda, com atendimento para eventos, empresas, feiras, casamentos e operações industriais.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a class="btn-primary" href={getWhatsappUrl()} target="_blank" rel="noopener noreferrer">
          <MessageCircle class="h-5 w-5" aria-hidden="true" />
          Solicitar Orçamento no WhatsApp
        </a>
        <a class="btn-secondary" href="#modelos">
          Conhecer Modelos de Tendas
          <ArrowRight class="h-5 w-5" aria-hidden="true" />
        </a>
      </div>
    </div>

    <div class="absolute bottom-16 right-4 hidden max-w-xs rounded-2xl border border-white/20 bg-white/15 p-5 text-white shadow-2xl backdrop-blur md:block lg:right-8">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-amber-200">Atendimento consultivo</p>
      <p class="mt-2 text-sm leading-6 text-white/85">Dimensionamento, logística e orientação para locação ou compra conforme o tipo de evento.</p>
    </div>
  </div>
</section>
