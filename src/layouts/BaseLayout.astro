---
import '../styles/global.css';
import { SEO } from 'astro-seo';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import { site } from '../data/site';
import {
  buildAutoBreadcrumbs,
  buildBreadcrumbSchema,
  buildLocalBusinessSchema,
  buildWebPageSchema,
  buildWebSiteSchema,
} from '../data/schema';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  noindex?: boolean;
  pageSchemaType?: string;
  structuredData?: Record<string, unknown>[];
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  title,
  description,
  image = site.ogImage,
  canonicalURL: canonicalURLProp,
  type = 'website',
  noindex = false,
  pageSchemaType = 'WebPage',
  structuredData = [],
  breadcrumbs,
} = Astro.props;

const normalizeCanonicalURL = (url: string | URL) => {
  const normalized = new URL(url, Astro.site ?? site.siteUrl);
  normalized.pathname = normalized.pathname
    .replace(/\/index\.html$/, '/')
    .replace(/\.html$/, '');

  if (normalized.pathname !== '/') {
    normalized.pathname = normalized.pathname.replace(/\/$/, '');
  }

  normalized.search = '';
  normalized.hash = '';

  return normalized.href;
};

const canonicalURL = normalizeCanonicalURL(canonicalURLProp ?? Astro.url);
const sameAs = [site.social.facebook, site.social.instagram, site.social.linkedin].filter(
  (url) => typeof url === 'string' && /^https?:\/\//.test(url)
);
const currentPath = new URL(canonicalURL).pathname;
const breadcrumbItems = breadcrumbs ?? buildAutoBreadcrumbs(canonicalURL);
const structuredDataNodes = [
  buildLocalBusinessSchema(),
  ...(currentPath === '/' ? [buildWebSiteSchema()] : []),
  buildWebPageSchema({
    url: canonicalURL,
    title,
    description,
    type: pageSchemaType,
    image,
  }),
  ...structuredData,
  ...(breadcrumbItems.length ? [buildBreadcrumbSchema(breadcrumbItems)] : []),
];
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="512x512" href={site.favicon} />
    <link rel="shortcut icon" href={site.favicon} />
    <link rel="apple-touch-icon" href={site.favicon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="CNOEsYWBpuJ3BaObIxQg9tSQKR46eMk1s6K-XT8nX80" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MNXTVPNFG7"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MNXTVPNFG7');
    </script>
    <SEO
      title={title}
      titleTemplate={`%s | ${site.name}`}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      openGraph={{
        basic: {
          title,
          type,
          image,
          url: canonicalURL,
        },
        optional: {
          siteName: site.name,
          description,
          locale: 'pt_BR',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        site: site.twitterHandle,
        title,
        description,
        image,
      }}
      extend={{
        meta: [
          { name: 'theme-color', content: '#103f2a' },
        ],
      }}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(
        structuredDataNodes.map((node) =>
          node['@type'] === 'LocalBusiness' && sameAs.length ? { ...node, sameAs } : node
        )
      )}
    />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>
